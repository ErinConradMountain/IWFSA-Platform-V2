{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@iwfsa/common/*": ["apps/common/src/*"]
    }
  },
  "include": ["api/**/*.ts", "apps/**/*.ts", "scripts/**/*.mjs"]
}
